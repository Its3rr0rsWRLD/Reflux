{
  "name": "reflux-installer",
  "version": "1.0.0",
  "description": "Installer for Reflux — Fluxer mod loader",
  "private": true,
  "main": "gui/main.js",
  "scripts": {
    "cli": "node cli/index.js",
    "gui": "electron gui/main.js",
    "build": "node build.js"
  },
  "reflux": {
    "githubRepo": "its3rr0rswrld/Reflux"
  },
  "dependencies": {
    "@electron/asar": "^3.2.13"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "latest",
    "electron": "^41.0.0",
    "electron-builder": "latest"
  },
  "build": {
    "appId": "dev.reflux.installer",
    "productName": "Reflux Installer",
    "copyright": "Reflux contributors",
    "directories": {
      "output": "dist"
    },
    "files": [
      "gui/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "gui/worker.js"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "reflux-v${version}-win-x64-setup.exe"
    }
  }
}
